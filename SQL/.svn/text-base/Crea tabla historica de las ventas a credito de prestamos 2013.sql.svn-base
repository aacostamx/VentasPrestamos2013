use VentasPrestamos
go

insert into VentasCreditoPrestamos
select NumeroCliente,importe,interesesFinanciar,SaldoPrestamoAnterior,fechamovimiento 
from ODS.Ene2013.dbo.movMensualMovtosPrestamos
where Clavemovimiento = 'S' AND TipoMovimiento = 'A' 
